/* result.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.video-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.video-player {
  width: 100%;
  height: 400rpx;
}

.info-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.platform-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
  margin-bottom: 16rpx;
}

.platform-badge.douyin { background: #FE2C55; }
.platform-badge.kuaishou { background: #FF4906; }
.platform-badge.bilibili { background: #00A1D6; }
.platform-badge.xiaohongshu { background: #FE2C55; }

.title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.download-btn, .share-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.download-btn {
  background: linear-gradient(135deg, #07C160 0%, #06AE56 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

.share-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
}

.hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.back-link {
  text-align: center;
  margin-top: 40rpx;
}

.back-link text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  text-decoration: underline;
}

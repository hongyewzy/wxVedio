/* index.wxss */
.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.input-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.input-box {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.url-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.placeholder {
  color: #999;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.paste-btn, .parse-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.paste-btn {
  background: #f0f0f0;
  color: #666;
}

.parse-btn {
  background: linear-gradient(135deg, #07C160 0%, #06AE56 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
}

.hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.platform-tags {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 48rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(8rpx);
}

.tips {
  text-align: center;
  margin-top: 40rpx;
}

.tips text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
